from openai import OpenAI
import os
import json

# Initialize client
client = OpenAI(
    api_key=os.environ.get("UNITYSVC_API_KEY"),
    base_url=os.environ.get("SERVICE_BASE_URL")  # can be left blank if using default OpenAI endpoint
)

# Example function
def echo_message(message):
    return f"Echo: {message}"

# Create the chat completion request
response = client.chat.completions.create(
    model="{{offering.name}}",  # keep this template!
    messages=[
        {"role": "system", "content": "You are a helpful assistant."},
        {"role": "user", "content": "This is a test"}
    ],
    tools=[
        {
            "type": "function",
            "function": {
                "name": "echo_message",
                "description": "Echoes back the given message",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "message": {
                            "type": "string",
                            "description": "The message to echo"
                        }
                    },
                    "required": ["message"]
                }
            }
        }
    ],
    tool_choice="auto"
)

# Get the model's first message
message = response.choices[0].message

# Handle tool call if it exists
if message.tool_calls:
    for tool_call in message.tool_calls:
        function_name = tool_call.function.name
        function_args = json.loads(tool_call.function.arguments)

        if function_name == "echo_message":
            result = echo_message(function_args["message"])
            print(result)
else:
    # No tool call — just print model output
    print(message.content or "⚠️ No content returned from model.")
